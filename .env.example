# ============================================================
# DISCORD BOT
# ============================================================
# Lấy từ: https://discord.com/developers/applications → Bot → Reset Token
BOT_TOKEN=your_bot_token_here

# General Information → Application ID
CLIENT_ID=your_client_id_here

# Chuột phải tên server → Copy Server ID (bật Developer Mode trước)
GUILD_ID=your_guild_id_here

# Chuột phải channel #level-up → Copy Channel ID
LEVELUP_CHANNEL_ID=your_levelup_channel_id_here

# ============================================================
# ROLE IDs (Chuột phải tên role → Copy Role ID)
# ============================================================
ROLE_DONG=role_id_for_dong
ROLE_BAC=role_id_for_bac
ROLE_VANG=role_id_for_vang

# ============================================================
# DASHBOARD
# ============================================================
DASHBOARD_PORT=3001

# Bắt buộc thay đổi! Chuỗi ngẫu nhiên dài ít nhất 32 ký tự
DASHBOARD_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars

# Tài khoản đăng nhập dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_password_here

# URL công khai để embed badge vào Discord (để trống nếu chạy local)
# VPS: BASE_URL=https://yourdomain.com
BASE_URL=
